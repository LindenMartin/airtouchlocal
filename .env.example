# AirTouch controller on your home network
AIRCON_HOST=10.0.0.200
AIRCON_USER=admin
AIRCON_PASSWORD=change-me

# Web server
HOST=0.0.0.0
PORT=4173

# Optional built-in safety layer. Strongly recommended outside localhost.
APP_USERNAME=airtouch
APP_PASSWORD=use-a-long-unique-password

# Container default; use ./backups when running Node directly if preferred.
DATA_DIR=/data
BACKUP_DIR=/data/backups

# Optional outside weather forecast. You can also set this in the UI.
WEATHER_LOCATION=Home
WEATHER_LAT=
WEATHER_LON=
WEATHER_TIMEZONE=auto
